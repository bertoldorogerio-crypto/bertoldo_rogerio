<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#fbbf24">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Bernardo Quest">
  <link rel="manifest" href="./manifest.json">
  <link rel="apple-touch-icon" href="./icons/icon-192.png">
  <title>Missões do Bernardo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800;900&family=Bangers&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body, #root { min-height: 100vh; min-height: 100dvh; background: #080b14; }
    body { font-family: 'Nunito', sans-serif; -webkit-tap-highlight-color: transparent; overscroll-behavior: none; }
    button { cursor: pointer; font-family: 'Nunito', sans-serif; -webkit-appearance: none; }

    @keyframes confettiFall { 0%{transform:translateY(-10px) rotate(0);opacity:1} 100%{transform:translateY(100vh) rotate(720deg);opacity:0} }
    @keyframes slideUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @keyframes pulseGlow { 0%,100%{box-shadow:0 0 8px #fbbf2444} 50%{box-shadow:0 0 24px #fbbf2466} }
    @keyframes spinSlow { to{transform:rotate(360deg)} }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
    @keyframes rankUpPulse { 0%{transform:scale(0.8);opacity:0} 50%{transform:scale(1.05)} 100%{transform:scale(1);opacity:1} }
    @keyframes rankUpBg { 0%{opacity:0} 20%{opacity:1} 80%{opacity:1} 100%{opacity:0} }
  </style>
</head>
<body>
  <div id="root"></div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js"></script>

  <script type="text/babel">
    const { useState, useEffect, useCallback } = React;

    /* ═══ STORAGE HELPER (localStorage) ═══ */
    const Storage = {
      get(key) {
        try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : null; }
        catch { return null; }
      },
      set(key, val) {
        try { localStorage.setItem(key, JSON.stringify(val)); return true; }
        catch { return false; }
      }
    };

    /* ═══ DATA ═══ */
    const QUESTS = [
      { id:"devocional", label:"Fazer Devocional", emoji:"📖", xp:10, theme:"naruto" },
      { id:"cama", label:"Arrumar a Cama", emoji:"🛏️", xp:10, theme:"pokemon" },
      { id:"mesa", label:"Arrumar a Mesa", emoji:"🍽️", xp:10, theme:"gumball" },
      { id:"cora", label:"Dar Comida pra Cora", emoji:"🐕", xp:10, theme:"onepiece" },
      { id:"lixo", label:"Levar Lixo pra Fora", emoji:"🗑️", xp:10, theme:"naruto" },
      { id:"loca", label:"Secar a Louça", emoji:"🧽", xp:10, theme:"pokemon" },
      { id:"licao", label:"Fazer Lição", emoji:"✏️", xp:10, optional:true, theme:"gumball" },
      { id:"leitura", label:"1 Hora de Leitura", emoji:"📚", xp:15, theme:"onepiece" },
    ];
    const BONUSES = [
      { id:"respeito", label:"Respeitar Pai e Mãe", emoji:"⭐", xp:20 },
      { id:"mesa_arrumada", label:"Deixar a Mesa Arrumada", emoji:"✨", xp:15 },
    ];
    const ALL_TASKS = [...QUESTS, ...BONUSES];
    const DAILY_MAX = QUESTS.reduce((s,q)=>s+q.xp,0) + BONUSES.reduce((s,b)=>s+b.xp,0);

    const RANKS = [
      { name:"Estudante da Academia", minXp:0, icon:"🎒", color:"#78909C", desc:"Todo ninja começa aqui!", arc:"naruto" },
      { name:"Genin", minXp:500, icon:"🌀", color:"#66BB6A", desc:"Aprovado no exame! Primeiro passo na jornada ninja.", arc:"naruto" },
      { name:"Chūnin", minXp:1200, icon:"⚡", color:"#42A5F5", desc:"Líder em formação, capaz de comandar missões.", arc:"naruto" },
      { name:"Jōnin", minXp:2200, icon:"🔥", color:"#FF7043", desc:"Guerreiro de elite da Vila da Folha!", arc:"naruto" },
      { name:"ANBU", minXp:3500, icon:"🐺", color:"#ab47bc", desc:"Operações secretas! A sombra que protege a vila.", arc:"naruto" },
      { name:"Hokage", minXp:5000, icon:"🏔️", color:"#EF5350", desc:"Líder supremo da Vila! Protege todos com sua vida.", arc:"naruto" },
      { name:"Sábio do Caminho", minXp:7000, icon:"☯️", color:"#e1bee7", desc:"Poder lendário! Domina todas as artes ninja.", arc:"naruto" },
      { name:"Pirata Novato", minXp:9000, icon:"⚓", color:"#4dd0e1", desc:"Zarpou pro Grand Line! A aventura começa!", arc:"onepiece" },
      { name:"Supernova", minXp:11000, icon:"💫", color:"#ffb74d", desc:"Recompensa de 100 milhões! O mundo conhece seu nome.", arc:"onepiece" },
      { name:"Shichibukai", minXp:13000, icon:"🗡️", color:"#7986cb", desc:"Um dos Sete Guerreiros do Mar!", arc:"onepiece" },
      { name:"Yonkou", minXp:15500, icon:"🦁", color:"#e57373", desc:"Imperador do Mar! Um dos quatro mais poderosos!", arc:"onepiece" },
      { name:"Rei dos Piratas", minXp:17500, icon:"👒", color:"#FFD700", desc:"Encontrou o One Piece! O maior de todos os mares!", arc:"onepiece" },
      { name:"Treinador Pokémon", minXp:19000, icon:"🧢", color:"#4fc3f7", desc:"Recebeu seu primeiro Pokémon! A jornada começa.", arc:"pokemon" },
      { name:"Líder de Ginásio", minXp:20000, icon:"🏅", color:"#aed581", desc:"Conquistou todos os ginásios da região!", arc:"pokemon" },
      { name:"Elite Four", minXp:20800, icon:"⚔️", color:"#ce93d8", desc:"Faz parte da Elite dos Quatro!", arc:"pokemon" },
      { name:"Mestre Pokémon", minXp:21200, icon:"🏆", color:"#AB47BC", desc:"Derrotou o campeão! Gotta catch 'em all!", arc:"pokemon" },
      { name:"Lenda Suprema", minXp:21600, icon:"👑", color:"#FF6F00", desc:"O MAIOR DE TODOS! Completou a jornada inteira!", arc:"legend" },
    ];

    const WEEK_BADGES = [
      { name:"Semana Bronze", minXp:300, icon:"🥉", color:"#cd7f32" },
      { name:"Semana Prata", minXp:550, icon:"🥈", color:"#c0c0c0" },
      { name:"Semana Ouro", minXp:720, icon:"🥇", color:"#ffd700" },
      { name:"Semana LENDÁRIA", minXp:840, icon:"💎", color:"#00e5ff" },
    ];

    /* ═══ HELPERS ═══ */
    const pad=n=>String(n).padStart(2,"0");
    const toKey=d=>`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
    const getToday=()=>toKey(new Date());
    const getMonthKey=s=>s.substring(0,7);
    const getDow=s=>["Dom","Seg","Ter","Qua","Qui","Sex","Sáb"][new Date(s+"T12:00:00").getDay()];
    const formatDate=s=>new Date(s+"T12:00:00").toLocaleDateString("pt-BR",{day:"numeric",month:"long"});
    function getRank(xp){let r=RANKS[0];for(const x of RANKS)if(xp>=x.minXp)r=x;return r;}
    function getNext(xp){for(const r of RANKS)if(xp<r.minXp)return r;return null;}
    function getWeekBadge(xp){let b=null;for(const x of WEEK_BADGES)if(xp>=x.minXp)b=x;return b;}
    function getMonthDates(mk){const[y,m]=mk.split("-").map(Number);return Array.from({length:new Date(y,m,0).getDate()},(_,i)=>`${y}-${pad(m)}-${pad(i+1)}`);}
    function getWeekDates(ds){const d=new Date(ds+"T12:00:00");const mon=new Date(d);mon.setDate(d.getDate()-((d.getDay()+6)%7));return Array.from({length:7},(_,i)=>{const x=new Date(mon);x.setDate(mon.getDate()+i);return toKey(x);});}
    function getCalGrid(mk){const[y,m]=mk.split("-").map(Number);const sd=new Date(y,m-1,1).getDay();const dim=new Date(y,m,0).getDate();const c=[];for(let i=0;i<sd;i++)c.push(null);for(let i=1;i<=dim;i++)c.push(`${y}-${pad(m)}-${pad(i)}`);while(c.length%7)c.push(null);return c;}
    const prevMonth=mk=>{const[y,m]=mk.split("-").map(Number);return m===1?`${y-1}-12`:`${y}-${pad(m-1)}`;};
    const nextMonth=mk=>{const[y,m]=mk.split("-").map(Number);return m===12?`${y+1}-01`:`${y}-${pad(m+1)}`;};
    const monthLabel=mk=>{const[y,m]=mk.split("-").map(Number);return new Date(y,m-1).toLocaleDateString("pt-BR",{month:"long",year:"numeric"});};
    const arcColors={naruto:"#FF7043",onepiece:"#fbbf24",pokemon:"#AB47BC",legend:"#FF6F00"};

    /* ═══ SVG ART ═══ */
    const Pokeball=({size=40,style={}})=>(
      <svg width={size} height={size} viewBox="0 0 100 100" style={style}>
        <circle cx="50" cy="50" r="46" fill="none" stroke="#EF5350" strokeWidth="4"/>
        <path d="M4,50 A46,46 0 0,1 96,50" fill="#EF5350" opacity="0.9"/>
        <path d="M4,50 A46,46 0 0,0 96,50" fill="#f5f5f5" opacity="0.9"/>
        <rect x="4" y="47" width="92" height="6" fill="#333" rx="3"/>
        <circle cx="50" cy="50" r="12" fill="#333"/><circle cx="50" cy="50" r="8" fill="#f5f5f5" stroke="#333" strokeWidth="2.5"/>
      </svg>
    );
    const Shuriken=({size=40,style={}})=>(
      <svg width={size} height={size} viewBox="0 0 100 100" style={{...style,animation:"spinSlow 8s linear infinite"}}>
        <g fill="#94a3b8" opacity="0.85"><polygon points="50,2 62,40 50,50 38,40"/><polygon points="98,50 60,62 50,50 60,38"/><polygon points="50,98 38,60 50,50 62,60"/><polygon points="2,50 40,38 50,50 40,62"/></g>
        <circle cx="50" cy="50" r="7" fill="#475569"/><circle cx="50" cy="50" r="3" fill="#1e293b"/>
      </svg>
    );
    const StrawHat=({size=50,style={}})=>(
      <svg width={size} height={size*0.68} viewBox="0 0 120 82" style={style}>
        <ellipse cx="60" cy="62" rx="56" ry="16" fill="#f59e0b" stroke="#d97706" strokeWidth="2"/>
        <ellipse cx="60" cy="44" rx="36" ry="26" fill="#fbbf24" stroke="#d97706" strokeWidth="2"/>
        <rect x="24" y="39" width="72" height="7" rx="3" fill="#EF5350"/>
      </svg>
    );
    const GumballFace=({size=44,style={}})=>(
      <svg width={size} height={size} viewBox="0 0 100 100" style={style}>
        <circle cx="50" cy="50" r="44" fill="#42A5F5" stroke="#1e88e5" strokeWidth="3"/>
        <ellipse cx="37" cy="40" rx="7" ry="9" fill="#fff"/><ellipse cx="63" cy="40" rx="7" ry="9" fill="#fff"/>
        <circle cx="39" cy="41" r="3.5" fill="#1a1a2e"/><circle cx="65" cy="41" r="3.5" fill="#1a1a2e"/>
        <circle cx="41" cy="39" r="1.2" fill="#fff"/><circle cx="67" cy="39" r="1.2" fill="#fff"/>
        <path d="M36,60 Q50,76 64,60" fill="none" stroke="#1a1a2e" strokeWidth="2.5" strokeLinecap="round"/>
      </svg>
    );
    const ArcBadge=({arc})=>{
      const map={naruto:{label:"Arco Naruto",color:"#FF7043",bg:"#FF704318"},onepiece:{label:"Arco One Piece",color:"#fbbf24",bg:"#fbbf2418"},pokemon:{label:"Arco Pokémon",color:"#AB47BC",bg:"#AB47BC18"},legend:{label:"LENDÁRIO",color:"#FF6F00",bg:"#FF6F0018"}};
      const a=map[arc]||map.naruto;
      return <span style={{fontSize:9,padding:"2px 8px",borderRadius:20,background:a.bg,color:a.color,fontWeight:800,letterSpacing:0.5}}>{a.label}</span>;
    };

    function Confetti({active}){
      if(!active)return null;
      const ps=Array.from({length:40},(_,i)=>({id:i,left:Math.random()*100,delay:Math.random()*0.5,dur:1.3+Math.random()*1.6,color:["#FFD700","#FF6B35","#42A5F5","#66BB6A","#AB47BC","#EF5350","#00e5ff","#fbbf24"][i%8],size:5+Math.random()*10}));
      return <div style={{position:"fixed",inset:0,pointerEvents:"none",zIndex:9999}}>{ps.map(p=><div key={p.id} style={{position:"absolute",left:`${p.left}%`,top:-10,width:p.size,height:p.size,borderRadius:p.size>9?"50%":"2px",background:p.color,animation:`confettiFall ${p.dur}s ${p.delay}s ease-in forwards`}}/>)}</div>;
    }

    /* ═══════════════ MAIN APP ═══════════════ */
    function App() {
      const [data,setData]=useState({});
      const [tab,setTab]=useState("daily");
      const [loaded,setLoaded]=useState(false);
      const [confetti,setConfetti]=useState(false);
      const [animQ,setAnimQ]=useState(null);
      const [calMonth,setCalMonth]=useState(getMonthKey(getToday()));
      const [selDay,setSelDay]=useState(null);
      const [rankUpAnim,setRankUpAnim]=useState(null);

      const today=getToday();

      useEffect(()=>{
        const saved=Storage.get("bernardo-quests-v4");
        if(saved) setData(saved);
        setLoaded(true);
      },[]);

      const save=useCallback((nd)=>{
        setData(nd);
        Storage.set("bernardo-quests-v4",nd);
      },[]);

      const dayXp=useCallback((ds)=>{
        const dd=data[ds]||{};let xp=0;
        QUESTS.forEach(q=>{if(dd[q.id])xp+=q.xp;});
        BONUSES.forEach(b=>{if(dd[b.id])xp+=b.xp;});
        return xp;
      },[data]);

      const totalXp=useCallback(()=>{
        let t=0;
        for(const dk of Object.keys(data)){const dd=data[dk];QUESTS.forEach(q=>{if(dd[q.id])t+=q.xp;});BONUSES.forEach(b=>{if(dd[b.id])t+=b.xp;});}
        return t;
      },[data]);

      const weekXp=useCallback((ds)=>getWeekDates(ds).reduce((s,d)=>s+dayXp(d),0),[dayXp]);
      const monthXp=useCallback((mk)=>getMonthDates(mk).reduce((s,d)=>s+dayXp(d),0),[dayXp]);

      const isTodayFinalized=!!(data[today]&&data[today]._finalized);

      const finalizeDay=()=>{
        if(isTodayFinalized)return;
        if(!confirm("Finalizar o dia de hoje? Depois de finalizado, não será possível alterar as missões de hoje."))return;
        const dd=data[today]||{};
        save({...data,[today]:{...dd,_finalized:true}});
      };
      const resetDay=()=>{
        if(!confirm("Resetar o dia de hoje? Todos os checks serão desmarcados e o dia será reaberto."))return;
        const n={...data};delete n[today];save(n);
      };

      const toggle=(qid)=>{
        if(isTodayFinalized)return;
        const dd=data[today]||{};const done=!dd[qid];
        const nd={...data,[today]:{...dd,[qid]:done}};
        const oldT=totalXp();let newT=oldT;
        const task=ALL_TASKS.find(t=>t.id===qid);
        if(task)newT=done?oldT+task.xp:oldT-task.xp;
        const oldR=getRank(oldT),newR=getRank(newT);
        if(done){
          setAnimQ(qid);setTimeout(()=>setAnimQ(null),500);
          if(newR.name!==oldR.name&&newT>oldT){
            setTimeout(()=>{setRankUpAnim(newR);setConfetti(true);setTimeout(()=>{setRankUpAnim(null);setConfetti(false);},4000);},300);
          }
          const nday=nd[today];
          const allDone=QUESTS.filter(q=>!q.optional).every(q=>nday[q.id])&&BONUSES.every(b=>nday[b.id]);
          if(allDone&&!rankUpAnim){setConfetti(true);setTimeout(()=>setConfetti(false),3000);}
        }
        save(nd);
      };

      const txp=dayXp(today),total=totalXp(),rank=getRank(total),next=getNext(total),wk=weekXp(today),td=data[today]||{};
      const daysPlayed=Object.keys(data).filter(k=>dayXp(k)>0).length;

      if(!loaded)return(
        <div style={{minHeight:"100vh",minHeight:"100dvh",background:"#080b14",display:"flex",alignItems:"center",justifyContent:"center",flexDirection:"column",gap:14}}>
          <div style={{fontSize:48,animation:"spinSlow 1s linear infinite"}}>⚡</div>
          <div style={{color:"#fbbf24",fontFamily:"'Nunito',sans-serif",fontSize:14}}>Carregando missões...</div>
        </div>
      );

      const TABS=[{id:"daily",label:"Missões",icon:"⚔️"},{id:"calendar",label:"Calendário",icon:"📅"},{id:"monthly",label:"Rankings",icon:"🏆"},{id:"rules",label:"Como Jogar",icon:"📜"}];

      return(
        <div style={S.wrap}>
          <Confetti active={confetti}/>

          {/* RANK UP OVERLAY */}
          {rankUpAnim&&(
            <div style={S.rankUpOverlay}>
              <div style={S.rankUpBox}>
                <div style={{fontSize:14,color:"#94a3b8",letterSpacing:3,textTransform:"uppercase"}}>RANK UP!</div>
                <div style={{fontSize:60,margin:"10px 0"}}>{rankUpAnim.icon}</div>
                <div style={{fontSize:24,fontWeight:900,color:rankUpAnim.color,fontFamily:"'Bangers',cursive",letterSpacing:2}}>{rankUpAnim.name}</div>
                <ArcBadge arc={rankUpAnim.arc}/>
                <div style={{fontSize:12,color:"#7c8ba8",marginTop:8,maxWidth:260,textAlign:"center"}}>{rankUpAnim.desc}</div>
              </div>
            </div>
          )}

          {/* HERO */}
          <div style={S.hero}>
            <div style={S.heroDeco}>
              <div style={{position:"absolute",top:6,right:8,animation:"float 4s ease-in-out infinite"}}><Pokeball size={52}/></div>
              <div style={{position:"absolute",bottom:4,left:10}}><Shuriken size={44}/></div>
              <div style={{position:"absolute",top:2,left:"32%",animation:"float 5s ease-in-out infinite 1s"}}><StrawHat size={56}/></div>
              <div style={{position:"absolute",bottom:10,right:"25%",animation:"float 3.5s ease-in-out infinite 0.5s"}}><GumballFace size={40}/></div>
            </div>
            <div style={{position:"relative",zIndex:2}}>
              <div style={{fontSize:11,color:"#7c8ba8",letterSpacing:3,textTransform:"uppercase"}}>Missões Diárias de</div>
              <h1 style={S.heroTitle}>BERNARDO</h1>
              <div style={S.rankRowH}>
                <span style={{fontSize:28}}>{rank.icon}</span>
                <div>
                  <div style={{fontSize:9,color:"#4a5568",textTransform:"uppercase",letterSpacing:1}}>Rank Atual</div>
                  <div style={{fontSize:16,fontWeight:900,color:rank.color}}>{rank.name}</div>
                  <ArcBadge arc={rank.arc}/>
                </div>
                <div style={{marginLeft:"auto",textAlign:"right"}}>
                  <div style={S.xpChip}>{total.toLocaleString()} XP</div>
                  <div style={{fontSize:9,color:"#4a5568",marginTop:3}}>{daysPlayed} dias jogados</div>
                </div>
              </div>
              {next&&<div style={{marginTop:12}}>
                <div style={{display:"flex",justifyContent:"space-between",fontSize:9,color:"#3a4050",marginBottom:3}}>
                  <span>{rank.icon} {rank.name}</span><span>{next.icon} {next.name} ({next.minXp.toLocaleString()})</span>
                </div>
                <div style={S.track}><div style={{...S.fill,width:`${Math.min(100,((total-rank.minXp)/(next.minXp-rank.minXp))*100)}%`,background:`linear-gradient(90deg,${rank.color},${next.color})`}}/></div>
                <div style={{fontSize:9,color:"#3a4050",marginTop:3,textAlign:"center"}}>Faltam <strong style={{color:next.color}}>{(next.minXp-total).toLocaleString()}</strong> XP para {next.icon} {next.name}</div>
              </div>}
            </div>
          </div>

          {/* STATS */}
          <div style={S.stats}>
            {[{v:txp,c:"#fbbf24",l:"Hoje",svg:<Shuriken size={18}/>},{v:wk,c:"#42A5F5",l:"Semana",svg:<StrawHat size={26}/>},{v:total,c:"#66BB6A",l:"Total",svg:<Pokeball size={18}/>}].map((s,i)=>(
              <div key={i} style={S.statBox}><div style={{opacity:0.4}}>{s.svg}</div><div style={{fontSize:18,fontWeight:900,color:s.c}}>{s.v.toLocaleString()}</div><div style={S.statLbl}>{s.l}</div></div>
            ))}
          </div>

          {/* TABS */}
          <div style={S.tabBar}>
            {TABS.map(t=><button key={t.id} onClick={()=>{setTab(t.id);setSelDay(null);}} style={{...S.tabBtn,...(tab===t.id?S.tabOn:{})}}>
              <span style={{fontSize:15}}>{t.icon}</span><span style={{fontSize:10}}>{t.label}</span>
            </button>)}
          </div>

          {/* ═══ DAILY ═══ */}
          {tab==="daily"&&<div style={S.pg}>
            <div style={S.animeBanner}>
              {[{svg:<Shuriken size={32}/>,name:"Naruto",c:"#FF7043"},{svg:<StrawHat size={40}/>,name:"One Piece",c:"#fbbf24"},{svg:<Pokeball size={30}/>,name:"Pokémon",c:"#EF5350"},{svg:<GumballFace size={30}/>,name:"Gumball",c:"#42A5F5"}].map((a,i)=>(
                <div key={i} style={S.animePill}>{a.svg}<span style={{fontSize:9,color:a.c,fontWeight:800}}>{a.name}</span></div>
              ))}
            </div>
            <div style={{marginBottom:14}}>
              <div style={{display:"flex",justifyContent:"space-between",fontSize:12}}>
                <span style={{color:"#7c8ba8"}}>Progresso de Hoje</span>
                <span style={{color:"#fbbf24",fontWeight:800}}>{txp}/{DAILY_MAX} XP</span>
              </div>
              <div style={{...S.track,height:10,marginTop:6}}><div style={{...S.fill,height:10,width:`${(txp/DAILY_MAX)*100}%`,background:"linear-gradient(90deg,#fbbf24,#22c55e)"}}/></div>
            </div>

            <div style={{display:"flex",flexDirection:"column",gap:6}}>
              {QUESTS.map((q,i)=>{
                const done=!!td[q.id],anim=animQ===q.id;
